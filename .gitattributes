# WordPress Plugin Release Configuration
# Files/directories marked with export-ignore are excluded from GitHub release ZIPs

# Development and documentation
/.cache export-ignore
/.github export-ignore
/.git export-ignore
/.gitattributes export-ignore
/.gitignore export-ignore
/.vscode export-ignore
/docs export-ignore
/backup-utility-scripts export-ignore
/scripts export-ignore
/tmp export-ignore
/tools export-ignore

# Docker development
/docker-compose.yml export-ignore
/docker-compose-test.yml export-ignore
/setup-docker.sh export-ignore
/wp-config-extra.php export-ignore
/wp-content export-ignore
DOCKER-QUICKREF.txt export-ignore

# Development documentation (keep README.md and LICENSE for users)
DESIGN_MIGRATION_COMPLETE.md export-ignore
OPTIMIZATION_STATUS.md export-ignore

# Composer development dependencies
/vendor export-ignore
composer.json export-ignore
composer.lock export-ignore

# Pro modules (separate product)
/pro-modules export-ignore
