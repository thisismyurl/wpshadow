{
	"name": "thisismyurl/core-support-thisismyurl",
	"description": "The Hub of the @thisismyurl Support Suite. Provides Multi-Engine Fallback, Encryption, Cloud Bridge, and Killer Features.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"authors": [
		{
			"name": "Christopher Ross",
			"email": "info@thisismyurl.com",
			"homepage": "https://thisismyurl.com"
		}
	],
	"require": {
		"php": ">=8.4"
	},
	"require-dev": {
		"phpunit/phpunit": "^11.0",
		"phpstan/phpstan": "^1.10",
		"squizlabs/php_codesniffer": "^3.8",
		"wp-coding-standards/wpcs": "^3.0"
	},
	"autoload": {
		"psr-4": {
			"TIMU\\CoreSupport\\": "includes/"
		}
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"scripts": {
		"phpcs": "phpcs --standard=WordPress-Extra",
		"phpcbf": "phpcbf --standard=WordPress-Extra",
		"phpstan": "phpstan analyse --memory-limit=512M",
		"test": "phpunit"
	}
}
