{
  "name": "thisismyurl/thisismyurl-shadow",
  "description": "Development tooling for the This Is My URL Shadow plugin.",
  "type": "project",
  "license": "GPL-2.0-or-later",
  "require-dev": {
    "phpunit/phpunit": "^13.1",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "phpstan/phpstan": "^1.11",
    "squizlabs/php_codesniffer": "^3.10",
    "wp-coding-standards/wpcs": "^3.1"
  },
  "scripts": {
    "test:smoke": "php scripts/smoke-test.php",
    "test:phpunit": "phpunit --configuration phpunit.xml.dist",
    "release:prepare": "bash scripts/prepare-wordpress-org-release.sh",
    "lint:phpcs": "phpcs --standard=phpcs.xml.dist .",
    "lint:phpstan": "phpstan analyse --configuration=phpstan.neon ."
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
