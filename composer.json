{
	"name": "wpshadow/plugin-wpshadow",
	"description": "The foundational plugin for all wpshadow plugin-* repositories. Provides the backbone architecture for hub and spoke plugins.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"authors": [
		{
			"name": "Christopher Ross",
			"email": "info@wpshadow.com",
			"homepage": "https://wpshadow.com"
		}
	],
	"require": {
		"php": ">=8.1.29"
	},
	"require-dev": {
		"phpunit/phpunit": "^11.0",
		"phpstan/phpstan": "^1.10",
		"squizlabs/php_codesniffer": "^3.8",
		"wp-coding-standards/wpcs": "^3.0"
	},
	"autoload": {
		"psr-4": {
			"WPShadow\\": "includes/"
		}
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"scripts": {
		"phpcs": [
			"phpcs --standard=WordPress-Extra includes features wpshadow.php",
			"bash .devcontainer/lib/track-phpcs.sh"
		],
		"phpcbf": "phpcbf --standard=WordPress-Extra includes features wpshadow.php",
		"phpstan": "phpstan analyse --memory-limit=512M includes features wpshadow.php",
		"test": [
			"phpunit",
			"bash .devcontainer/lib/track-tests.sh"
		],
		"kpi": "bash .devcontainer/check-dev-kpis.sh"
	}
}

