{
    "name": "wpshadow/plugin-wpshadow",
    "description": "WPShadow core plugin: diagnostics, recovery, and management for WordPress.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Christopher Ross",
            "email": "info@wpshadow.com",
            "homepage": "https://wpshadow.com"
        }
    ],
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.8",
        "wp-coding-standards/wpcs": "^3.0",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "phpunit/phpunit": "^9.5",
        "10up/wp_mock": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "WPShadow\\": "includes/"
        },
        "classmap": [
            "includes/core/",
            "includes/diagnostics/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "WPShadow\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "composer/installers": true
        }
    },
    "scripts": {
        "phpcs": "vendor/bin/phpcs -d memory_limit=512M --standard=WordPress-Extra includes wpshadow.php",
        "phpcbf": "vendor/bin/phpcbf --standard=WordPress-Extra includes wpshadow.php",
        "phpstan": "vendor/bin/phpstan analyse --memory-limit=512M includes wpshadow.php",
        "test": "vendor/bin/phpunit"
    }
}
