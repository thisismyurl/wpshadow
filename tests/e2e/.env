# WordPress E2E Testing Environment Variables
# Copy this file to .env and update with your values

# WordPress URL (where your test WordPress site is running)
WP_BASE_URL=https://wpshadow.com

# WordPress Admin Credentials
WP_ADMIN_USER=github
WP_ADMIN_PASS=github

# Test Configuration
# HEADLESS=false  # Set to false to see browser during tests
# SLOWMO=100      # Slow down operations by X milliseconds for debugging
