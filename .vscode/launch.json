{
    // WPShadow PHP Debugging Configuration
    "version": "0.2.0",
    "configurations": [
        {
            "name": "🔴 Listen for Xdebug (Docker)",
            "type": "php",
            "request": "launch",
            "port": 9003,
            "pathMappings": {
                "/var/www/html/wp-content/plugins/wpshadow": "${workspaceFolder}",
                "/var/www/html": "${workspaceFolder}/../wordpress-docker"
            },
            "log": false,
            "xdebugSettings": {
                "max_data": 65535,
                "show_hidden": 1,
                "max_children": 100,
                "max_depth": 5
            },
            "presentation": {
                "group": "debug",
                "order": 1
            }
        },
        {
            "name": "🐛 Debug Current PHP File",
            "type": "php",
            "request": "launch",
            "program": "${file}",
            "cwd": "${fileDirname}",
            "port": 0,
            "runtimeArgs": [
                "-dxdebug.start_with_request=yes"
            ],
            "env": {
                "XDEBUG_MODE": "debug,develop",
                "XDEBUG_CONFIG": "client_port=${port}"
            },
            "presentation": {
                "group": "debug",
                "order": 2
            }
        },
        {
            "name": "🏗️ Debug WordPress Admin Load",
            "type": "php",
            "request": "launch",
            "program": "${workspaceFolder}/debug-wp-admin.php",
            "cwd": "${workspaceFolder}",
            "port": 0,
            "runtimeArgs": [
                "-dxdebug.mode=debug",
                "-dxdebug.start_with_request=yes"
            ],
            "env": {
                "WP_DEBUG": "1"
            },
            "presentation": {
                "group": "debug",
                "order": 3
            }
        },
        {
            "name": "🔎 Debug Single Diagnostic",
            "type": "php",
            "request": "launch",
            "program": "${workspaceFolder}/debug-diagnostic.php",
            "cwd": "${workspaceFolder}",
            "port": 0,
            "runtimeArgs": [
                "-dxdebug.mode=debug",
                "-dxdebug.start_with_request=yes",
                "-d",
                "error_reporting=E_ALL"
            ],
            "presentation": {
                "group": "debug",
                "order": 4
            }
        },
        {
            "name": "⚙️ Debug Treatment Apply/Undo",
            "type": "php",
            "request": "launch",
            "program": "${workspaceFolder}/debug-treatment.php",
            "cwd": "${workspaceFolder}",
            "port": 0,
            "runtimeArgs": [
                "-dxdebug.mode=debug",
                "-dxdebug.start_with_request=yes",
                "-d",
                "error_reporting=E_ALL"
            ],
            "presentation": {
                "group": "debug",
                "order": 5
            }
        },
        {
            "name": "🧪 Debug AJAX Handler",
            "type": "php",
            "request": "launch",
            "program": "${workspaceFolder}/debug-ajax.php",
            "cwd": "${workspaceFolder}",
            "port": 0,
            "runtimeArgs": [
                "-dxdebug.mode=debug",
                "-dxdebug.start_with_request=yes",
                "-d",
                "error_reporting=E_ALL"
            ],
            "presentation": {
                "group": "debug",
                "order": 6
            }
        }
    ]
}
