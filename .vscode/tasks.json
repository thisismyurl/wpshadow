{
    "version": "2.0.0",
    "tasks": [
        // === Guardian Angel: Safety Checks ===
        {
            "label": "🛡️ Guardian: Pre-Work Check",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/guardian-check.sh",
            "runOptions": {
                "runOn": "folderOpen"
            },
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "focus": true
            },
            "problemMatcher": [],
            "group": {
                "kind": "test",
                "isDefault": true
            }
        },
        // === Git Workflow ===
        {
            "label": "Git: Check Sync Status",
            "type": "shell",
            "command": "bash",
            "args": [
                "${workspaceFolder}/scripts/git-sync-check.sh"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Git: Quick Commit & Push",
            "type": "shell",
            "command": "bash",
            "args": [
                "${workspaceFolder}/scripts/git-auto-commit.sh",
                "${input:commitMessage}"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        // === Testing & Validation ===
        {
            "label": "Test: PHP Syntax Check",
            "type": "shell",
            "command": "find ${workspaceFolder}/includes ${workspaceFolder}/wpshadow.php -name '*.php' -not -path '*/vendor/*' -not -path '*/documented/*' -exec php -l {} \\; | grep -v 'No syntax errors'",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Test: WordPress Load Check",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/test-wp-load.sh",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Test: phpcs (Coding Standards)",
            "type": "shell",
            "command": "composer phpcs",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Test: phpstan (Static Analysis)",
            "type": "shell",
            "command": "composer phpstan",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Test: Full Quality Check",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Test: PHP Syntax Check",
                "Test: phpcs (Coding Standards)",
                "Test: phpstan (Static Analysis)"
            ],
            "problemMatcher": []
        },
        // === Docker Management ===
        {
            "label": "Docker: Start All Services",
            "type": "shell",
            "command": "cd ${workspaceFolder} && docker-compose up -d && sleep 5 && docker-compose ps",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": []
        },
        {
            "label": "Docker: Restart Test Environment",
            "type": "shell",
            "command": "docker restart wpshadow-test && sleep 5 && echo '✅ Test environment restarted'",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Docker: View Logs (Test)",
            "type": "shell",
            "command": "docker logs -f wpshadow-test",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": [],
            "isBackground": true
        },
        {
            "label": "Docker: Stop All Services",
            "type": "shell",
            "command": "cd ${workspaceFolder} && docker-compose down",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        // === Development Shortcuts ===
        {
            "label": "Dev: Watch PHP Errors",
            "type": "shell",
            "command": "docker exec -it wpshadow-test tail -f /var/www/html/wp-content/debug.log",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": [],
            "isBackground": true
        },
        {
            "label": "Dev: Clear All Caches",
            "type": "shell",
            "command": "docker exec wpshadow-test wp cache flush --allow-root && echo '✅ Caches cleared'",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Dev: Database Backup",
            "type": "shell",
            "command": "docker exec wpshadow-test wp db export /tmp/backup-$(date +%Y%m%d-%H%M%S).sql --allow-root",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        // === Complete Workflows ===
        {
            "label": "🚀 Full Workflow: Sync → Test → Commit",
            "dependsOrder": "sequence",
            "dependsOn": [
                "🛡️ Guardian: Pre-Work Check",
                "Test: Full Quality Check",
                "Git: Quick Commit & Push"
            ],
            "problemMatcher": []
        },
        {
            "label": "🎯 Quick Fix Workflow: Test → Commit",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Test: PHP Syntax Check",
                "Git: Quick Commit & Push"
            ],
            "problemMatcher": []
        },
        // === Keep-Alive ===
        {
            "label": "🔄 Keep-Alive: Start Session Keeper",
            "type": "shell",
            "command": "pgrep -f 'bash scripts/keep-alive.sh' > /dev/null 2>&1 && echo '✓ Keep-alive already running' || (nohup ${workspaceFolder}/scripts/keep-alive.sh > /dev/null 2>&1 & echo '✓ Keep-alive started')",
            "presentation": {
                "reveal": "silent"
            },
            "problemMatcher": []
        },
        {
            "label": "🔄 Keep-Alive: View Activity Log",
            "type": "shell",
            "command": "tail -f /tmp/wpshadow-keep-alive.log",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": [],
            "isBackground": true
        },
        // === Auto-Continue: 25-Task Prompt Auto-Accept ===
        {
            "label": "🤖 Auto-Continue: Start Layer 2 Watcher",
            "type": "shell",
            "command": "pgrep -f 'bash scripts/auto-continue-watcher.sh' > /dev/null 2>&1 && echo '✓ Auto-continue watcher running' || (nohup ${workspaceFolder}/scripts/auto-continue-watcher.sh > /dev/null 2>&1 & echo '✓ Auto-continue watcher started')",
            "presentation": {
                "reveal": "silent"
            },
            "problemMatcher": []
        },
        {
            "label": "🤖 Auto-Continue: View Watcher Logs",
            "type": "shell",
            "command": "tail -f /tmp/auto-continue-watcher.log",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": [],
            "isBackground": true
        },
        {
            "label": "🤖 Auto-Continue: Manual Accept Trigger",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/auto-continue-watcher.sh",
            "presentation": {
                "reveal": "silent"
            },
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "commitMessage",
            "type": "promptString",
            "description": "Commit message (e.g., 'feat: add new diagnostic')",
            "default": ""
        }
    ]
}
