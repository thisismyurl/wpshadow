            "if (!current_user_can('${3:manage_options}')) {",
            "\twp_die(__('Insufficient permissions', 'wpshadow'));",
            "}",
            "",
            "// SECURITY: Sanitize input",
            "\\$${4:param} = sanitize_text_field(\\$_POST['${4:param}'] ?? '');"
        ],
