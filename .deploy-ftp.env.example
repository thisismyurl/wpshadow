# FTP Deployment Configuration for GreenGeeks
# Copy this file to .deploy-ftp.env and fill in your details

# FTP Server Details
FTP_HOST=mtl202.greengeeks.net
FTP_PORT=21
FTP_USER=github@wpshadow.com
FTP_PASSWORD=your-password-here

# Path to WordPress plugins directory on server
FTP_REMOTE_PATH=/public_html/wpshadow/wp-content/plugins/wpshadow

# Optional: Use FTP over SSL (FTPS)
# Set to "yes" to enable, "no" to disable
FTP_SSL=no
