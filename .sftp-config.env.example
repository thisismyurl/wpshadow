# SFTP Deployment Configuration
# Copy this file to .sftp-config.env and fill in your details

SFTP_HOST=your-server.com
SFTP_PORT=22
SFTP_USER=your-username
SFTP_PASSWORD=your-password
# OR use key-based auth (recommended):
SFTP_KEY_FILE=~/.ssh/id_rsa

# Remote path to WordPress plugins directory
SFTP_REMOTE_PATH=/home/youruser/public_html/wp-content/plugins/wpshadow

# Files/folders to exclude from sync (space-separated)
EXCLUDE_PATTERNS=".git .gitignore node_modules vendor .env .sftp-config.env *.log"
