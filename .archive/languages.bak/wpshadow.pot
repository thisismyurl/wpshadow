#: features/class-wps-feature-consent-checks.php:292
msgid "Help us understand how visitors use our website."
msgstr ""

#: features/class-wps-feature-consent-checks.php:296
msgid "Marketing Cookies"
msgstr ""

#: features/class-wps-feature-consent-checks.php:297
msgid "Used to track visitors across websites for marketing purposes."
msgstr ""

#: features/class-wps-feature-consent-checks.php:300
msgid "Save Preferences"
msgstr ""

#: features/class-wps-feature-consent-checks.php:365
msgid "This website uses cookies to improve your experience. We use essential cookies to make our site work. With your consent, we may also use non-essential cookies to improve user experience and analyze website traffic."
