#!/bin/bash
# Auto-update reminder script
# Place in: .git/hooks/post-merge (after git pull)
# or schedule with: git config --local core.hooksPath .githooks

echo ""
echo "╔════════════════════════════════════════════════════════════════╗"
echo "║         WPSHADOW SETUP - Auto-Recovery Check                  ║"
echo "╚════════════════════════════════════════════════════════════════╝"
echo ""

# Check if Docker services are running
if command -v docker-compose &> /dev/null; then
    # Silently check status
    SERVICES=$(docker-compose ps 2>/dev/null | grep -c "Up" || echo "0")
    
    if [ "$SERVICES" -lt 2 ]; then
        echo "⚠️  Services not fully running. Starting..."
        docker-compose up -d 2>/dev/null
        sleep 3
        echo "✅ Services auto-started"
    else
        echo "✅ Services already running ($SERVICES active)"
    fi
else
    echo "ℹ️  Docker not available (local environment)"
fi

echo ""
echo "Ready for development! Run: docker-compose logs -f"
echo ""
