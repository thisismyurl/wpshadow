<script>
jQuery(document).ready(function($) {
	const $seoButton = $('#run-seo-scan-btn');
	if ($seoButton.length) {
		$seoButton.prop('disabled', false).attr('aria-busy', 'false');
	}

	$('#run-seo-scan-btn').on('click', function() {
		const $btn = $(this);
		const $progress = $('.scan-progress');
		const $progressFill = $progress.find('.progress-fill');
		const $progressBar = $progress.find('.progress-bar');
		const $progressText = $progress.find('.progress-text');
		const $progressPercent = $progress.find('.wps-report-progress-percent');
		const $results = $('#seo-scan-results');
		const $debugLog = $('#seo-debug-log');
		let progressValue = 0;
		let progressTimer = null;
		let statusTimer = null;
		let lastStatusSlug = '';
		let lastStatusState = '';
		let recoveryRequested = false;
		let completePolls = 0;
		let completedDiagnostics = 0;
		let completedSlugs = {};
		const totalDiagnostics = <?php echo (int) count( $seo_diagnostics ); ?>;

		const logDebug = (message) => {
			if (!$debugLog.length) {
				return;
			}
			const timestamp = new Date().toLocaleTimeString();
			$debugLog.prepend('<div>[' + timestamp + '] ' + message + '</div>');
			if (window.WPShadowAdmin && typeof window.WPShadowAdmin.appendProgressLog === 'function') {
				window.WPShadowAdmin.appendProgressLog(message);
			}
		};

		const startStatusPolling = () => {
			if (statusTimer) {
				window.clearInterval(statusTimer);
				statusTimer = null;
			}
			statusTimer = window.setInterval(() => {
				$.ajax({
					url: ajaxurl,
					method: 'POST',
					dataType: 'json',
					data: {
						action: 'wpshadow_diagnostics_status',
						family: 'seo',
						nonce: $btn.data('nonce')
					},
					timeout: 5000
				}).done(function(response) {
					if (!response || !response.success || !response.data) {
						return;
					}
					const status = response.data;
					const now = Math.floor(Date.now() / 1000);
					const updatedAge = status.updated ? Math.max(0, now - status.updated) : null;
					if (status.slug && status.slug !== lastStatusSlug) {
						lastStatusSlug = status.slug;
						logDebug('Server now running: ' + status.slug);
						if (window.console && console.log) {
							console.log('[WPShadow] Running diagnostic:', status.slug);
						}
					} else if (!status.slug && status.last_slug && status.last_slug !== lastStatusSlug) {
						lastStatusSlug = status.last_slug;
						logDebug('Last diagnostic completed: ' + status.last_slug);
					}

					if (status.last_slug && !completedSlugs[status.last_slug]) {
						completedSlugs[status.last_slug] = true;
						completedDiagnostics += 1;
						if (window.console && console.log) {
							console.log('[WPShadow] Completed diagnostic:', status.last_slug);
						}
						if (totalDiagnostics > 0) {
							const percent = Math.min(100, Math.round((completedDiagnostics / totalDiagnostics) * 100));
							updateProgress(percent, '<?php echo esc_js( __( 'Running SEO diagnostics...', 'wpshadow' ) ); ?> ' + completedDiagnostics + '/' + totalDiagnostics);
						}
					}
					if (status.state && status.state !== lastStatusState) {
						lastStatusState = status.state;
						completePolls = 0;
						logDebug('Server state changed: ' + status.state);
					}
					if (status.state && status.state !== 'running' && status.state !== 'starting') {
						logDebug('Server status: ' + status.state);
					}
					if (status.state === 'complete' || status.state === 'timed_out') {
						completePolls += 1;
					}

					if (!requestCompleted && (status.state === 'complete' || status.state === 'timed_out') && !status.results) {
						logDebug('Status complete but results missing.');
						if (!recoveryRequested) {
							recoveryRequested = true;
							$.ajax({
								url: ajaxurl,
								method: 'POST',
								dataType: 'json',
								data: {
									action: 'wpshadow_last_family_results',
									family: 'seo',
									nonce: $btn.data('nonce')
								},
								timeout: 5000
							}).done(function(fallbackResponse) {
								if (!fallbackResponse || !fallbackResponse.success || !fallbackResponse.data || !fallbackResponse.data.results) {
									logDebug('Fallback results not available yet.');
									recoveryRequested = false;
									return;
								}
								const results = fallbackResponse.data.results;
								const payload = {
									findings: results.findings || [],
									stats: results.stats || {},
									total_diagnostics: results.total || 0,
									timed_out: results.timed_out || false
								};
								requestCompleted = true;
								if (request && request.abort) {
									request.abort();
								}
								logDebug('Recovered results from fallback fetch.');
								displaySEOResults(payload);
								if (payload.timed_out) {
									$results.prepend('<div class="notice notice-warning"><p><?php echo esc_js( __( 'The scan finished early to keep things fast. You can run it again for a fuller pass.', 'wpshadow' ) ); ?></p></div>');
								}
								finishProgress('<?php echo esc_js( __( 'Report ready.', 'wpshadow' ) ); ?>');
								stopStatusPolling();
								$btn.prop('disabled', false).removeClass('wps-loading');
							}).fail(function() {
								logDebug('Fallback results request failed.');
								recoveryRequested = false;
							});
						}
						if (completePolls >= 5 && !recoveryRequested) {
							logDebug('Completing scan without results after repeated polls.');
							requestCompleted = true;
							stopStatusPolling();
							$results.html('<div class="notice notice-warning"><p><?php echo esc_js( __( 'The scan finished, but the results did not load. Please refresh and try again.', 'wpshadow' ) ); ?></p></div>');
							finishProgress('<?php echo esc_js( __( 'Report completed.', 'wpshadow' ) ); ?>');
							$btn.prop('disabled', false).removeClass('wps-loading');
						}
					}

					if (!requestCompleted && status.results && status.results.findings) {
						requestCompleted = true;
						if (request && request.abort) {
							request.abort();
						}
						const payload = {
							findings: status.results.findings,
							stats: status.results.stats || {},
							total_diagnostics: status.results.total || 0,
							timed_out: status.results.timed_out || false
						};
						logDebug('Recovered results from status polling.');
						displaySEOResults(payload);
						if (payload.timed_out) {
							$results.prepend('<div class="notice notice-warning"><p><?php echo esc_js( __( 'The scan finished early to keep things fast. You can run it again for a fuller pass.', 'wpshadow' ) ); ?></p></div>');
						}
						finishProgress('<?php echo esc_js( __( 'Report ready.', 'wpshadow' ) ); ?>');
						stopStatusPolling();
						$btn.prop('disabled', false).removeClass('wps-loading');
					}

					if (window.WPShadowAdmin && typeof window.WPShadowAdmin.setProgressCurrent === 'function') {
						if (status.slug) {
							window.WPShadowAdmin.setProgressCurrent('<?php echo esc_js( __( 'Current diagnostic:', 'wpshadow' ) ); ?> ' + status.slug);
						} else if (status.last_slug) {
							window.WPShadowAdmin.setProgressCurrent('<?php echo esc_js( __( 'Last diagnostic:', 'wpshadow' ) ); ?> ' + status.last_slug);
						} else {
							window.WPShadowAdmin.setProgressCurrent('');
						}
						if (updatedAge !== null) {
							window.WPShadowAdmin.setProgressCurrent(
								(window.WPShadowAdmin && window.WPShadowAdmin.setProgressCurrent ? '' : '')
							);
						}
					}
				});
			}, 2000);
		};

		const stopStatusPolling = () => {
			if (statusTimer) {
				window.clearInterval(statusTimer);
				statusTimer = null;
			}
		};

		const updateProgress = (value, message) => {
			const clamped = Math.max(0, Math.min(100, value));
			$progressFill.css('width', clamped + '%');
			$progressBar.attr('aria-valuenow', clamped);
			$progressPercent.text(clamped + '%');
			if (message) {
				$progressText.text(message);
				logDebug('Progress ' + clamped + '% - ' + message);
			}
		};

		const statusMessages = [
			'<?php echo esc_js( __( 'Checking sitemap and index settings...', 'wpshadow' ) ); ?>',
			'<?php echo esc_js( __( 'Reviewing page titles and meta descriptions...', 'wpshadow' ) ); ?>',
			'<?php echo esc_js( __( 'Checking mobile readiness...', 'wpshadow' ) ); ?>',
			'<?php echo esc_js( __( 'Analyzing internal links...', 'wpshadow' ) ); ?>',
			'<?php echo esc_js( __( 'Reviewing structured data markup...', 'wpshadow' ) ); ?>',
			'<?php echo esc_js( __( 'Checking social sharing tags...', 'wpshadow' ) ); ?>',
			'<?php echo esc_js( __( 'Scanning performance signals...', 'wpshadow' ) ); ?>'
		];
		const performanceSignals = [
			'<?php echo esc_js( __( 'Scanning performance signals: server response time', 'wpshadow' ) ); ?>',
			'<?php echo esc_js( __( 'Scanning performance signals: page load speed', 'wpshadow' ) ); ?>',
			'<?php echo esc_js( __( 'Scanning performance signals: image weight', 'wpshadow' ) ); ?>',
			'<?php echo esc_js( __( 'Scanning performance signals: script size', 'wpshadow' ) ); ?>',
			'<?php echo esc_js( __( 'Scanning performance signals: caching hints', 'wpshadow' ) ); ?>',
			'<?php echo esc_js( __( 'Scanning performance signals: layout stability', 'wpshadow' ) ); ?>'
		];
		let performanceSignalIndex = 0;

		const startProgress = () => {
			progressValue = 5;
			updateProgress(progressValue, '<?php echo esc_js( __( 'Preparing SEO checks...', 'wpshadow' ) ); ?>');
			progressTimer = window.setInterval(() => {
				const increment = Math.floor(Math.random() * 8) + 3;
				progressValue = Math.min(90, progressValue + increment);
				const messageIndex = Math.floor((progressValue / 90) * statusMessages.length);
				let message = statusMessages[Math.min(statusMessages.length - 1, messageIndex)];
				if (progressValue >= 85) {
					message = performanceSignals[performanceSignalIndex % performanceSignals.length];
					performanceSignalIndex += 1;
				}
				updateProgress(progressValue, message);
			}, 500);
		};

		const finishProgress = (message) => {
			if (progressTimer) {
				window.clearInterval(progressTimer);
				progressTimer = null;
			}
			updateProgress(100, message || '<?php echo esc_js( __( 'Finalizing report...', 'wpshadow' ) ); ?>');
			logDebug('Progress complete - ' + (message || 'Finalizing report...'));
			window.setTimeout(() => {
				$progress.addClass('hidden');
				updateProgress(0, '<?php echo esc_js( __( 'Preparing SEO checks...', 'wpshadow' ) ); ?>');
			}, 900);
		};

		$btn.prop('disabled', true).addClass('wps-loading');
		$progress.removeClass('hidden');
		$results.empty();
		startProgress();
		startStatusPolling();
		let requestCompleted = false;
		let requestTimeout = null;

		const handleTimeout = () => {
			if (requestCompleted) {
				return;
			}
			requestCompleted = true;
			if (request && request.abort) {
				request.abort();
			}
			logDebug('Request timed out after 30s');
			$results.html('<div class="notice notice-error"><p><?php echo esc_js( __( 'The report is taking longer than expected. Please try again.', 'wpshadow' ) ); ?></p></div>');
			finishProgress('<?php echo esc_js( __( 'Report timed out. Please try again.', 'wpshadow' ) ); ?>');
			$btn.prop('disabled', false).removeClass('wps-loading');
		};

		requestTimeout = window.setTimeout(handleTimeout, 25000);
		logDebug('Request started');
		const payload = {
			action: 'wpshadow_run_family_diagnostics',
			family: 'seo',
			nonce: $btn.data('nonce')
		};
		logDebug('ajaxurl: ' + (typeof ajaxurl !== 'undefined' ? ajaxurl : 'undefined'));
		logDebug('nonce present: ' + (payload.nonce ? 'yes' : 'no'));
		if (typeof ajaxurl === 'undefined') {
			logDebug('Error: ajaxurl is not defined.');
		}
		let request = null;
		try {
			request = $.ajax({
				url: ajaxurl,
				method: 'POST',
				dataType: 'json',
				data: payload,
				timeout: 20000
			});
		} catch (error) {
			logDebug('Request threw error: ' + (error && error.message ? error.message : 'unknown'));
			finishProgress('<?php echo esc_js( __( 'Report failed. Please try again.', 'wpshadow' ) ); ?>');
			$btn.prop('disabled', false).removeClass('wps-loading');
			return;
		}

		request.done(function(response) {
			requestCompleted = true;
			if (requestTimeout) {
				window.clearTimeout(requestTimeout);
				requestTimeout = null;
			}
			const responseData = response && response.success === true ? response.data : response;
			if (response && response.success === false) {
				logDebug('Request returned error response.');
				$results.html('<div class="notice notice-error"><p>' + (response.data && response.data.message ? response.data.message : '<?php echo esc_js( __( 'Report failed. Please try again.', 'wpshadow' ) ); ?>') + '</p></div>');
				finishProgress('<?php echo esc_js( __( 'Report failed. Please try again.', 'wpshadow' ) ); ?>');
				return;
			}
			logDebug('Request success');
			if (responseData && responseData.timed_out) {
				$results.html('<div class="notice notice-warning"><p><?php echo esc_js( __( 'The scan finished early to keep things fast. You can run it again for a fuller pass.', 'wpshadow' ) ); ?></p></div>');
			}
			displaySEOResults(responseData || {});
			saveSnapshot(responseData || {}, $btn.data('snapshot-nonce'));
			finishProgress('<?php echo esc_js( __( 'Report ready.', 'wpshadow' ) ); ?>');
		}).fail(function(jqXHR, textStatus, errorThrown) {
			requestCompleted = true;
			if (requestTimeout) {
				window.clearTimeout(requestTimeout);
				requestTimeout = null;
			}
			const responseMessage = jqXHR && jqXHR.responseJSON && jqXHR.responseJSON.data && jqXHR.responseJSON.data.message
				? jqXHR.responseJSON.data.message
				: null;
			const errorMessage = responseMessage || errorThrown || textStatus || '<?php echo esc_js( __( 'Report failed. Please try again.', 'wpshadow' ) ); ?>';
			const statusCode = jqXHR && jqXHR.status ? jqXHR.status : 'unknown';
			const responseSnippet = jqXHR && jqXHR.responseText ? jqXHR.responseText.substring(0, 200) : '';
			logDebug('Request failed: ' + errorMessage);
			logDebug('HTTP status: ' + statusCode + ' (' + textStatus + ')');
			if (responseSnippet) {
				logDebug('Response: ' + responseSnippet.replace(/\s+/g, ' '));
			}
			$results.html('<div class="notice notice-error"><p>' + errorMessage + '</p></div>');
			finishProgress('<?php echo esc_js( __( 'Report failed. Please try again.', 'wpshadow' ) ); ?>');
		}).always(function() {
			stopStatusPolling();
			logDebug('Request completed');
			$btn.prop('disabled', false).removeClass('wps-loading');
		});
	});

	function saveSnapshot(data, nonce) {
		if (!nonce) {
			return;
		}

		wp.ajax.post('wpshadow_save_snapshot', {
			report_id: 'seo-report',
			data: JSON.stringify(data || {}),
			metadata: JSON.stringify({ source: 'seo-report' }),
			nonce: nonce
		}).done(function(response) {
			updatePastReports(response && response.snapshot);
		});
	}

	function updatePastReports(snapshot) {
		const $card = $('#seo-past-reports-card');
		const $list = $('#seo-past-reports-list');
		const $empty = $('#seo-past-reports-empty');

		if (!snapshot || !$card.length) {
			return;
		}

		if ($empty.length) {
			$empty.remove();
		}

		if (!$list.length) {
			$card.append('<ul class="wps-list-disc wps-ml-5" id="seo-past-reports-list"></ul>');
		}

		const $targetList = $('#seo-past-reports-list');
		const issuesText = snapshot.findings_count ? snapshot.findings_count : 0;
		const timeText = snapshot.created_at ? snapshot.created_at : '<?php echo esc_js( __( 'Just now', 'wpshadow' ) ); ?>';
		const listItem = '<li class="wps-mb-2"><span class="wps-text-xs wps-text-muted">' +
			timeText + ' • ' + issuesText + ' <?php echo esc_js( __( 'issues', 'wpshadow' ) ); ?>' +
			'</span></li>';

		$targetList.prepend(listItem);
	}

	function displaySEOResults(data) {
		const $results = $('#seo-scan-results');
		const findings = data.findings || [];
		const seoScore = Math.max(0, 100 - (findings.length * 5));

		const visibilityIssues = findings.filter(f => f.title && f.title.toLowerCase().includes('visibility')).length;
		const mobileIssues = findings.filter(f => f.title && f.title.toLowerCase().includes('mobile')).length;
		const metaIssues = findings.filter(f => f.title && (f.title.toLowerCase().includes('meta') || f.title.toLowerCase().includes('title'))).length;

		$('#seo-visibility-status').text(visibilityIssues === 0 ? '<?php echo esc_js( __( 'Good', 'wpshadow' ) ); ?>' : visibilityIssues + ' <?php echo esc_js( __( 'issues', 'wpshadow' ) ); ?>');
		$('#seo-mobile-status').text(mobileIssues === 0 ? '<?php echo esc_js( __( 'Yes', 'wpshadow' ) ); ?>' : '<?php echo esc_js( __( 'Issues found', 'wpshadow' ) ); ?>');
		$('#seo-meta-issues').text(metaIssues);
		$('#seo-score').text(seoScore + '/100');

		if (findings.length === 0) {
			$results.html('<div class="notice notice-success wps-card"><p><span class="dashicons dashicons-yes-alt"></span> <?php echo esc_js( __( 'Great news! No SEO issues found.', 'wpshadow' ) ); ?></p></div>');
			return;
		}

		const critical = findings.filter(f => f.severity === 'critical' || f.severity === 'high');
		const moderate = findings.filter(f => f.severity === 'medium');
		const minor = findings.filter(f => f.severity === 'low');

		let html = '<div class="wps-card"><div class="wps-card-body">';
		html += '<h3 class="wps-text-lg wps-mb-3"><?php echo esc_js( __( 'SEO Issues Found', 'wpshadow' ) ); ?> (' + findings.length + ')</h3>';

		if (critical.length > 0) {
			html += '<h4 class="wps-font-semibold wps-text-error wps-mb-2"><?php echo esc_js( __( 'High Priority', 'wpshadow' ) ); ?> (' + critical.length + ')</h4>';
			critical.forEach(function(finding) {
				html += renderSEOFinding(finding, 'error');
			});
		}

		if (moderate.length > 0) {
			html += '<h4 class="wps-font-semibold wps-text-warning wps-mt-4 wps-mb-2"><?php echo esc_js( __( 'Medium Priority', 'wpshadow' ) ); ?> (' + moderate.length + ')</h4>';
			moderate.forEach(function(finding) {
				html += renderSEOFinding(finding, 'warning');
			});
		}

		if (minor.length > 0) {
			html += '<h4 class="wps-font-semibold wps-text-info wps-mt-4 wps-mb-2"><?php echo esc_js( __( 'Low Priority', 'wpshadow' ) ); ?> (' + minor.length + ')</h4>';
			minor.forEach(function(finding) {
				html += renderSEOFinding(finding, 'info');
			});
		}

		html += '</div></div>';
		$results.html(html);
	}

	function renderSEOFinding(finding, severity) {
		let html = '<div class="wps-mb-3 wps-p-3 wps-border wps-border-' + severity + ' wps-rounded">';
		html += '<div class="wps-flex wps-items-start wps-gap-3">';
		html += '<span class="dashicons dashicons-info wps-text-' + severity + '"></span>';
		html += '<div class="wps-flex-1">';
		html += '<h5 class="wps-font-semibold">' + finding.title + '</h5>';
		html += '<p class="wps-text-muted wps-text-sm">' + finding.description + '</p>';

		if (finding.threat_level) {
			const impact = finding.threat_level > 70 ? '<?php echo esc_js( __( 'High impact on visibility', 'wpshadow' ) ); ?>' :
						finding.threat_level > 40 ? '<?php echo esc_js( __( 'Moderate impact', 'wpshadow' ) ); ?>' :
						'<?php echo esc_js( __( 'Low impact', 'wpshadow' ) ); ?>';
			html += '<p class="wps-text-xs wps-text-muted wps-mt-1"><strong><?php echo esc_js( __( 'Impact:', 'wpshadow' ) ); ?></strong> ' + impact + '</p>';
		}

		if (finding.kb_link) {
			html += '<a href="' + finding.kb_link + '" target="_blank" class="wps-btn wps-btn-sm wps-btn-link wps-mt-2"><?php echo esc_js( __( 'Learn More', 'wpshadow' ) ); ?></a>';
		}
		html += '</div></div></div>';
		return html;
	}
});
</script>
