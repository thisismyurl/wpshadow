<?xml version="1.0"?>
<ruleset name="WPShadow">
	<description>WordPress Coding Standards for WPShadow Plugin</description>

	<!-- TODO: Remove exclusions as codebase becomes compliant -->
	<!-- Current: Relaxed for initial development -->
	<!-- Target: Full WordPress-Extra compliance -->

	<!-- Check all PHP files in directory tree by default. -->
	<arg name="extensions" value="php"/>
	<file>.</file>

	<!-- Show progress and sniff codes in all reports -->
	<arg value="ps"/>

	<!-- Exclude patterns -->
	<exclude-pattern>*/vendor/*</exclude-pattern>
	<exclude-pattern>*/node_modules/*</exclude-pattern>
	<exclude-pattern>*/tests/*</exclude-pattern>
	<exclude-pattern>*/build/*</exclude-pattern>
	<exclude-pattern>*/.git/*</exclude-pattern>
	<exclude-pattern>*/.venv/*</exclude-pattern>
	<exclude-pattern>*/docs/*</exclude-pattern>
	<exclude-pattern>*/tools/*</exclude-pattern>
	<exclude-pattern>*/.devcontainer/*</exclude-pattern>
	<exclude-pattern>*/bin/*</exclude-pattern>
	<exclude-pattern>*.min.js</exclude-pattern>
	<exclude-pattern>*.min.css</exclude-pattern>

	<!-- Use WordPress Coding Standards -->
	<rule ref="WordPress-Extra">
		<!-- Allow array short syntax -->
		<exclude name="Generic.Arrays.DisallowShortArraySyntax"/>
		<exclude name="Universal.Arrays.DisallowShortArraySyntax"/>
		
		<!-- Temporarily relax file comment requirements -->
		<exclude name="Squiz.Commenting.FileComment.Missing"/>
		<exclude name="Squiz.Commenting.FileComment.MissingPackageTag"/>
		
		<!-- Temporarily relax class comment requirements -->
		<exclude name="Squiz.Commenting.ClassComment.Missing"/>
	</rule>

	<!-- Use WordPress Documentation Standards -->
	<rule ref="WordPress-Docs"/>

	<!-- Check for PHP cross-version compatibility. -->
	<config name="testVersion" value="8.1-"/>
	<rule ref="PHPCompatibilityWP"/>

	<!-- Allow for plugin text domain -->
	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array" value="wpshadow"/>
		</properties>
	</rule>

	<!-- Naming conventions -->
	<rule ref="WordPress.NamingConventions.PrefixAllGlobals">
		<properties>
			<property name="prefixes" type="array" value="wpshadow,WPShadow"/>
		</properties>
	</rule>

	<!-- Array and ternary syntax -->
	<!-- Allow short array syntax [] but disallow short ternary ?: for clarity -->
	<rule ref="WordPress.PHP.DisallowShortTernary"/>

	<!-- File naming -->
	<rule ref="WordPress.Files.FileName">
		<properties>
			<property name="strict_class_file_names" value="false"/>
		</properties>
	</rule>
</ruleset>
