# Git Deployment Configuration for GreenGeeks
# Copy this file to .deploy-git.env and fill in your details

# GreenGeeks SSH access
REMOTE_HOST=your-site.greengeeks.net
REMOTE_USER=your-cpanel-username
REMOTE_PORT=22
SSH_KEY_FILE=~/.ssh/id_rsa

# Path to WordPress plugins directory on GreenGeeks
REMOTE_WP_PATH=/home/your-cpanel-user/public_html/wp-content/plugins/wpshadow

# Git branch to deploy (usually main or master)
DEPLOY_BRANCH=main
