/**
 * Add an admin notice to be displayed on next page load.
 * 
 * Stores the notice in a transient for display after redirect.
 * Useful for showing messages after form submission or action completion.
 * 
 * @param string $message The notice message text.
 * @param string $type The notice type ('warning', 'error', 'success', 'info').
 */
function wpshadow_add_admin_notice( string $message, string $type = 'warning' ): void {

	set_transient(
		'wpshadow_admin_notice',
		array(
			'message' => sanitize_text_field( $message ),
			'type'    => sanitize_key( $type ),
		),
		60
	);
}

/**
 * Render and display an admin notice.
 * 
 * Retrieves notice from transient and displays it as WordPress admin notice.
 * Automatically deletes the transient after display.
 * 
 * @hooked admin_notices
 */
function wpshadow_render_admin_notice(): void {
	$notice = get_transient( 'wpshadow_admin_notice' );
	if ( empty( $notice ) || ! is_array( $notice ) ) {
		return;
	}

	delete_transient( 'wpshadow_admin_notice' );

	$type    = $notice['type'] ?? 'updated';
	$message = $notice['message'] ?? '';
	if ( empty( $message ) ) {
		return;
	}

	$class = 'notice';
	switch ( $type ) {
		case 'error':
			$class .= ' notice-error';
			break;
		case 'warning':
			$class .= ' notice-warning';
			break;
		case 'success':
			$class .= ' notice-success';
			break;
		default:
			$class .= ' notice-info';
			break;
	}

	echo '<div class="' . esc_attr( $class ) . ' is-dismissible"><p>' . esc_html( $message ) . '</p></div>';
}

add_action( 'admin_notices', __NAMESPACE__ . '\wpshadow_render_admin_notice' );
add_action( 'network_admin_notices', __NAMESPACE__ . '\wpshadow_render_admin_notice' );

