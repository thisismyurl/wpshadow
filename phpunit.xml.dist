<?xml version="1.0" encoding="UTF-8"?>
<phpunit
	bootstrap="tests/bootstrap.php"
	cacheDirectory=".phpunit.cache"
	colors="true"
	executionOrder="default"
>
	<testsuites>
		<testsuite name="WPShadow Integration">
			<directory>tests</directory>
		</testsuite>
	</testsuites>
	<php>
		<env name="WPSHADOW_TEST_WP_ROOT" value="/workspaces/wp-smoke"/>
	</php>
</phpunit>