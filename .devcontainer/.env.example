# WPShadow Development Environment - Docker Compose Configuration
# This file contains example environment variables for Docker containers

# WordPress Configuration
WORDPRESS_DB_HOST=db
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=wordpress
WORDPRESS_DB_NAME=wordpress
WORDPRESS_TABLE_PREFIX=wp_
WORDPRESS_DEBUG=1
WORDPRESS_DEBUG_LOG=1
WORDPRESS_DEBUG_DISPLAY=0

# MySQL Configuration
MYSQL_ROOT_PASSWORD=wordpress
MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
MYSQL_PASSWORD=wordpress

# Docker Compose Configuration
COMPOSE_PROJECT_NAME=wpshadow
COMPOSE_FILE=docker-compose.yml

# PHP Configuration (if custom)
# PHP_MEMORY_LIMIT=256M
# PHP_MAX_UPLOAD_SIZE=64M
# PHP_MAX_EXECUTION_TIME=300

# Port Overrides (edit if ports 8080/8081 are in use)
# WORDPRESS_PORT=8080
# PHPMYADMIN_PORT=8081
# MYSQL_PORT=3306

# WordPress Site Configuration (for Codespaces, auto-configured)
# WORDPRESS_CONFIG_EXTRA for Codespaces is added in docker-compose.yml
