{
  "name": "WPShadow Development Environment",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "wordpress-test",
  "workspaceFolder": "/workspaces/wpshadow",
  // Features to install
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  // VS Code customizations
  "customizations": {
    "vscode": {
      "settings": {
        "files.autoSave": "afterDelay",
        "files.autoSaveDelay": 1000,
        "github.copilot.chat.maxRequests": 200,
        "github.copilot.chat.autoApproveFileWrites": true,
        "github.copilot.chat.autoApproveFileModifications": true,
        "github.copilot.chat.autoApproveFolderCreation": true,
        "github.copilot.chat.autoApproveFileReferences": true,
        // Set default chat participant to WPShadow Agent
        "github.copilot.chat.defaultParticipant": "wpshadow"
      },
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "bmewburn.vscode-intelephense-client",
        "ms-azuretools.vscode-docker"
      ]
    }
  },
  // Run commands on container creation
  "postCreateCommand": "bash .devcontainer/post-create.sh && nohup bash scripts/keep-alive.sh > /dev/null 2>&1 &",
  // Run commands when attaching to existing container
  "postAttachCommand": "bash .devcontainer/post-attach.sh && nohup bash scripts/keep-alive.sh > /dev/null 2>&1 &",
  // Forward ports
  "forwardPorts": [
    8080,
    9000
  ],
  // Port attributes
  "portsAttributes": {
    "8080": {
      "label": "WPShadow Site",
      "onAutoForward": "notify"
    },
    "9000": {
      "label": "WPShadow Test",
      "onAutoForward": "notify"
    }
  },
  // Remote user
  "remoteUser": "root",
  // Idle timeout: 120 minutes (max)
  "remoteEnv": {
    "CODESPACES_TIMEOUT": "120"
  }
}
